RenderLayer static_ui;
RenderLayer static_ui_foreground;
Camera world_cam = make_camera(90 * deg2rad, 0.01, 1000);

Shader shader_voxel_chunk;

Texture2D texture_spritesheet;

DrawBuffers db_quad3D;

bool is_freecam = true;
bool is_thirdperson = false;

Key key_jump                = .space;
Key key_open_inventory      = .E;
Key key_drop_item           = .Q;
Key key_thirdperson_toggle  = .backspace;
Key key_freecam_toggle      = .enter;

MouseButton mouse_primary_action = .Left;
MouseButton mouse_secondary_action = .Right;


struct BlockInfo {
    char* name;

    char* image_file_name;
    Image image;
    Texture2D texture;
    uint32 drop;
    ToolType tool;
}

const Block_Type_Count = 5;
BlockInfo[Block_Type_Count] block_types = {
    {"Air"},
    {"Stone",   "stone.bmp",    tool = .Pickaxe,  drop = 1 },
    {"Soil",    "soil.bmp",     tool = .Shovel,   drop = 2 },
    {"Grass",   "grass.bmp",    tool = .Shovel,   drop = 3 },
    {"Gravel",  "gravel.bmp",   tool = .Shovel,   drop = 7 }
};

enum ToolType {
    None; Axe; Pickaxe; Shovel;
}

struct Item { uint32 id, count; }
struct ItemInfo {
    char* name;
    char* image_file_name;
    Sprite sprite;
    uint32 sprite_index;
    ToolType tool;
    uint16 block_id;

}

ItemInfo[] item_infos = {
    {},
    {"Stone",   "stone.bmp",    block_id = 1 },
    {"Soil",    "soil.bmp",     block_id = 2 },
    {"Grass",   "grass.bmp",    block_id = 3 },
    {"Flint Hatchet", sprite_index = 0, tool = .Axe},
    {"Wood Shovel",   sprite_index = 1, tool = .Shovel},
    {"Flint Pickaxe", sprite_index = 2, tool = .Pickaxe},
    {"Rock",          sprite_index = 3 },
    {"Flint Rock",    sprite_index = 4 }
};

struct Recipe {
    Item product;
    Item[] ingredient;
}

Recipe[] recipes = {
    { product={4, 1}, ingredient={{8, 1}} }
};

Sprite sub_sprite(Sprite sp, uint32 sprite_index, sprite_pixel_size, num_cells) {
    uint32 w = sprite_pixel_size * num_cells;
    sp.uv_scale = make_vec2(sprite_pixel_size as float32 / w);

    uint32 x = sprite_index % num_cells;
    uint32 y = sprite_index / num_cells;
    sp.uv_offset = {x, y} * sp.uv_scale;

    return sp;
}


void main() {
    grax_init();
    gizmo_setup();
    init_draw2d();

    let renderer = deferred_renderer_init();
    let R = *renderer;
    R.sun_dir = {1, 0, 0};
    R.sun_radiance = {5, 5, 5};
    R.sun_ambient_factor = 0.05;

    static_ui = create_layer();
    static_ui_foreground = create_layer();
    immediate_layer = *static_ui;

    {
        float32 h = 0.5;
        float32 l = -h;
        vertex3D[] verts = {
            {{l, l, 0}, vec3_unit_z, {0,0}},
            {{l, h, 0}, vec3_unit_z, {0,1}},
            {{h, l, 0}, vec3_unit_z, {1,0}},
            {{h, h, 0}, vec3_unit_z, {1,1}}
        };

        uint32[] inds = { 0,2,1, 1,2,3 };

        db_quad3D = create_draw_buffers(verts, inds);
    }

    uint32 ss_size = (floorf(sqrtf(Block_Type_Count as float32)) + 1) as uint32;
    Image spritesheet = {};
    spritesheet.width = ss_size * 16;
    spritesheet.height = ss_size * 16;
    spritesheet.pixels = calloc(spritesheet.width * spritesheet.height, sizeof Color);

    for 0 .. Block_Type_Count {
        let bi = *block_types[it];
        if bi.image_file_name {
            bi.image = load_bitmap(concat("assets/", bi.image_file_name));

            uint32 x = (it % ss_size) * 16;
            uint32 y = (it / ss_size) * 16;

            image_blit(spritesheet, bi.image, x, y);

            bi.texture = create_texture2D(bi.image);
            set_filter(bi.texture, TextureFilter.nearest);
        }
    }

    texture_spritesheet = create_texture2D(spritesheet);
    set_filter(texture_spritesheet, TextureFilter.nearest);
    free(spritesheet.pixels);

    Sprite items_spritesheet = make_sprite(load_texture2D("assets/items.bmp"));

    for 0 .. item_infos.length {
        let info = *item_infos[it];
        if info.image_file_name {
            let image = load_bitmap(concat("assets/", info.image_file_name));
            info.sprite = make_sprite(create_texture2D(image));
            set_filter(info.sprite.tex, TextureFilter.nearest);
            free(image.pixels);
        } else {
            info.sprite = sub_sprite(items_spritesheet, info.sprite_index, 16, 4);
        }
    }

    world_cam.transform.position = {-10, 32, -10};


    for 0 .. Pool_Size {
        let chunk = *chunk_pool[it];
        chunk.coord = {99999,99999,99999};
    }

    while grax_loop() {
        ensure_chunks();

        if key_pressed(key_freecam_toggle) {
            player.tr.position = world_cam.transform.position;
            is_freecam = !is_freecam;
        }

        if key_pressed('R') {
            let sh = *R.shader_geometry;
            delete_shader(sh);
            @sh = load_shader(sh.name.chars);
        }


        float32 dt = 1.0/60.0; // deltatime();

        if is_freecam {
            enable_cursor();
            camera_fly_control(*world_cam, 0.05);
        } else {
            player_control(dt);
        }

        world_update(*world, dt);

        glDepthMask(true);
        glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT);
        draw_world(R, world_cam);
        gizmo_dispatch();
        dispatch_layer(*static_ui, {scale=1} as Transform2D);
        dispatch_sprites({scale=1} as Transform2D);
        dispatch_layer(*static_ui_foreground, {scale=1} as Transform2D);
    }
}

struct Checkbox_State {
    char* label;
    float32 time;
    bool state;
}

bool checkbox(UI_Rect rect, char* label) {


    static Checkbox_State[..] checkboxes = list_create(sizeof Checkbox_State);
    Checkbox_State* cb = null;
    for 0 .. list_length(checkboxes) {
        let c = *checkboxes[it];
        if c.label == label {
            cb = c;
            break;
        }
    }

    if cb == null {
        cb = list_append(*checkboxes);
        @cb = {};
        cb.label = label;
    }


    Color color = opacity(Black, 0.5);

    if hover(rect, Input.mouse_pos) {
        if mouse_pressed(MouseButton.Left) {
            cb.state = !cb.state;
        }

        color = opacity(Black, 0.8);
    }

    draw_rect(rect, color);

    UI_Rect check = rect;
    check.size = check.size*0.5;
    draw_rect(check, White);

    vec2 text_pos = rect.center + { rect.size.x/2.0 + rect.size.x/4.0, 0 };
    draw_text(text_pos, rect.size.y, label, White);

    return cb.state;
}

struct Block_Raycast_Result {
    ivec3 coord, prev_coord;
    uint16 block_id;
    float32 dist;
}

Block_Raycast_Result grid_raycast(vec3 o,d, float32 max_dist) {
    let ts = start_traversal(o, d);
    ivec3 prev_coord = {};

    while true {
        traverse(*ts);
        float32 dist = travel_distance(ts);
        if dist > max_dist break;

        uint16 id = get_block(ts.coord);
        if id {
            Block_Raycast_Result result = {};
            result.block_id = id;
            result.dist = dist;
            result.coord = ts.coord;
            result.prev_coord = prev_coord;
            return result;
        }

        prev_coord = ts.coord;
    }

    return {};
}

