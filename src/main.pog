void player_move_input(Entity* en, Camera cam, float32 dt) {

    vec3 f = noz(forward(cam.transform) * make_vec(1,0,1));
    vec3 s = noz(   left(cam.transform) * make_vec(1,0,1));

    let i = Input.wasd;
    vec3 movement = noz(f*i.y - s*i.x);

    static float32 max_speed = 3; // 4.317;
    static float32 acceleration = 30;

    // time it takes to go from 0 to max_speed given acceleration
    // max_speed / acceleration = seconds

    vec3 target_vel = movement*max_speed;
    target_vel.y = en.vel.y;
    en.vel = move(en.vel, target_vel, acceleration*dt);

    if en.is_grounded {
        if key_pressed(key_jump)  en.vel.y += 5;
    }

    draw_text(make_vec(0.1, 0), 0.05, to_string(length(en.vel)), White);
}

void player_control(float32 dt) {

    if key_pressed(key_thirdperson_toggle) {
        is_thirdperson = !is_thirdperson;
    }

    if key_pressed(key_open_inventory) {
        if player_backpack_open {
            player_backpack_open = false;
        } else {
            open_inventory(*player_hotbar, *player_backpack, null);
        }
    }



    /*
        thirdperson     open_inv    cursor
        false           false       disabled
        false           true        enabled
        true            false       enabled
        true            true        enabled
    */
    if is_thirdperson or player_backpack_open
        enable_cursor(); else disable_cursor();


    if !player_backpack_open  hotbar_selected_slot = (9 + hotbar_selected_slot as int32 - Input.mouse_scroll as int32) as uint32 % 9;
    Item* item_hand = player_held_item();

    if player_backpack_open {
        draw_inventory();
    } else {
        draw_hotbar(*player_hotbar, hotbar_selected_slot);
        draw_text(vec2_zero, 0.05, "X", White);

        if is_thirdperson {
            camera_orbit_control(*world_cam, player.tr.position);
        } else {
            rotate(*world_cam.transform, left(world_cam.transform), Input.mouse_delta.y * 2.0);
            rotate(*world_cam.transform, vec3_unit_y,               Input.mouse_delta.x * 2.0);
        }

        player_move_input(*player, world_cam, dt);

        if is_item(@item_hand) {
            if key_pressed(key_drop_item) {
                vec3 look_dir = forward(world_cam.transform); // forward(player.tr);
                Item item = {item_hand.id, 1};
                spawn_item(player.tr.position, look_dir*4, item, 3);

                item_count(item_hand, -1);
            }
        }

        item_action(item_hand, dt);
    }

    if key_pressed('F') {
        add_item(*player_hotbar, {4, 1} as Item);
        add_item(*player_hotbar, {5, 1} as Item);
        add_item(*player_hotbar, {6, 1} as Item);
        add_item(*player_hotbar, {7, 1} as Item);
        add_item(*player_hotbar, {8, 1} as Item);
    }

    if key_pressed(Key.P) {
        vec3 look_dir = forward(world_cam.transform); // forward(player.tr);
        spawn_entity(player.tr.position, look_dir*8);
    }


    if !is_thirdperson   player.tr.rotation = slerp(0.4, player.tr.rotation, world_cam.transform.rotation);

    entity_update(*player, dt);
    if !is_thirdperson  world_cam.transform.position = player.tr.position;
}

void item_action(Item* item, float32 dt) {

    ItemInfo item_info = item_infos[item.id];

    vec2 cursor_pos = cursor_enabled() ? Input.mouse_pos : vec2_zero;
    update_matrices(*world_cam);
    let o = world_cam.transform.position;
    let d = camera_ray(world_cam, cursor_pos);


    // TODO: we seem to have further reach with entity_raycast than grid_raycast so one of them must have a bug! related to distance calc
    float32 reach = 5;
    let target_block = grid_raycast(o,d, reach);
    let target_entity = entity_raycast(*world, o,d, reach);

    bool tool_swung = false;
    float32 tool_swing_power = 0;

    if item_info.tool {
        if mouse_down(mouse_primary_action) { // use tool
            player_tool_charge = clamp01(player_tool_charge + 2*dt);
        } else if mouse_released(mouse_primary_action) {
            tool_swing_power = player_tool_charge;
            player_tool_charge = 0;
            tool_swung = true;
        }
    }

    bool is_entity = target_entity.en != null;
    bool is_block = target_block.block_id != 0;

    if is_entity and is_block {
        is_entity = target_entity.min_dist <= target_block.dist;
        is_block = !is_entity;
    }

    if is_entity {
        gizmo_point(target_entity.hit_point, Red, 0.05);

        if tool_swung {
            uint32 damage = 10 * tool_swing_power;
            Entity* victim = target_entity.en;
            victim.vel = victim.vel + d*10;
        }

    } else if is_block {
        BlockInfo block_info = block_types[target_block.block_id];

        if item_info.tool {
            if item_info.tool == block_info.tool {
                gizmo_box(make_vec(target_block.coord), vec3_one, Black);

                if tool_swung and tool_swing_power > 0.7 {
                    set_block(target_block.coord, 0);

                    Item item_drop = {block_info.drop, 1};
                    spawn_item(make_vec(target_block.coord), random_unit_vec3() * 3, item_drop, 0.3);

                    // add_item(*player_hotbar, item_drop);
                }
            }
        } else if item_info.block_id {
            gizmo_box(make_vec(target_block.prev_coord), vec3_one, Black);

            if mouse_pressed(mouse_secondary_action) {
                set_block(target_block.prev_coord, item_info.block_id);
                item_count(item, -1);
            }
        }
    }

}

void draw_world(DeferredRenderer* R, Camera cam) {
    let time = app.total_run_time / 10.0;
    R.sun_dir = { cos(time), 0.7, sin(time) };
    // R.sun_dir = noz(forward(cam.transform));

    begin_geometry_pass(R, cam);

    world_draw(R, *world);

    if false {
        let chunk = last_chunk_interacted_with;
        if chunk {
            if chunk.must_remesh  update_octree(chunk);
            if chunk.octree {
                draw_octree(0, make_vec(chunk.coord*Chunk_Size) + vec3_one*(Chunk_Size/2.0 - 0.5), Chunk_Size, chunk.octree as Octree_Node*);
            }
        }
    }


    if false { // debug draw
        for 0 .. Pool_Size {
            let chunk = *chunk_pool[it];
            float32 size = Chunk_Size;
            vec3 pos = make_vec(chunk.coord)*size;
            gizmo_box(pos + vec3_one*(size/2.0 - 0.5), vec3_one*size, Orange);
        }
    }

    for 0 .. Pool_Size {
        let chunk = *chunk_pool[it];

        Material_PBR pbr = {
            albedo = {1,1,1},
            metallic = 0.1,
            roughness = 0.1
        };

        // uint32 gl_texture = white_texture.gl_handle;
        // uint32 gl_texture = block_types[1].texture.gl_handle;
        uint32 gl_texture = texture_spritesheet.gl_handle;

        float32 size = Chunk_Size;
        vec3 pos = make_vec(chunk.coord)*size;

        if chunk.must_remesh {
            triangulate_chunk(chunk);
            chunk.must_remesh = false;
        }


        set_depth_mode(DepthTest.Less_Equal, true);
        set_blend_mode(Blend.Overwrite);
        set_face_render_mode(Poly.Fill, Poly.Cull);
        draw_geometry(R, chunk.db, pbr, gl_texture, make_mat4(pos, 1));
    }


        // use(*shader_voxel_chunk);


    begin_light_pass(R);
    end_frame(R);
}
