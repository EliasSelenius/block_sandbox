void world_draw(DeferredRenderer* R, World* w) {

    Item* item_hand = player_held_item();
    if item_hand.id != 0 {
        ItemInfo info = item_infos[item_hand.id];

        vec3 offset = make_vec(-(player.aabb.size.x * 1.3 / 2.0), -0.3, 0.5);

        float32 d90 = Pi/4.0;
        float32 d45 = d90/2.0;
        quat rotation = axis_angle(vec3_unit_y, -d90*2) * axis_angle(vec3_unit_x, -(d90+d45));

        vec3 bottom_left = {-0.5, 0.5, 0};
        quat tool_charge_rot = axis_angle(vec3_unit_z, d90 * player_tool_charge);
        let model = rotate(mat4_id, tool_charge_rot, bottom_left) * make_mat4(offset, vec3_one, rotation) * to_matrix(player.tr);
        Material_PBR mat = {{1,1,1}, 0.1, 0.1};
        draw_quad(R, info.sprite, mat, model);
    }


    for 0 .. list_length(w.entity_pool) {
        let en = *w.entity_pool[it];

        if en.item_stack.id {
            ItemInfo info = item_infos[en.item_stack.id];

            Transform tr = en.tr;
            tr.scale = tr.scale * en.aabb.size;
            mat4 model = to_matrix(tr);

            Material_PBR mat = {{1,1,1}, 0.1, 0.1};
            draw_quad(R, info.sprite, mat, model);
        }
    }
}



struct Inventory {
    uint32 rows, cols;
    Item* items;
}

Inventory make_inventory(uint32 rows, cols) {
    Inventory inv = {};
    inv.rows = rows;
    inv.cols = cols;
    inv.items = calloc(rows * cols, sizeof Item);
    return inv;
}

void item_count(Item* item, int32 change) {
    item.count += change;
    if item.count == 0   item.id = 0;
}

Item* inv_item(Inventory* inv, uint32 x, y) return *inv.items[y*inv.cols + x];

bool is_item(Item item) return item.id != 0 and item.count != 0;

Item* get_first_empty_slot(Inventory* inv) {
    for 0 .. inv.rows*inv.cols {
        Item* item = *inv.items[it];
        if !is_item(@item) return item;
    }

    return null;
}

int32 get_slot_index_for(Inventory* inv, uint32 item_id) {
    for 0 .. inv.rows*inv.cols {
        Item item = inv.items[it];
        if item.id == item_id and item.count != 0  return it;
    }

    for 0 .. inv.rows*inv.cols {
        Item item = inv.items[it];
        if !is_item(item) return it;
    }

    return -1;
}

bool add_item(Inventory* inv, Item item) {
    for 0 .. inv.rows*inv.cols {
        Item* slot = *inv.items[it];
        if slot.count != 0 and slot.id == item.id {
            slot.count += item.count;
            return true;
        }
    }

    let slot = get_first_empty_slot(inv);
    if slot {
        @slot = item;
        return true;
    }

    return false;
}


struct UI_Slot {
    Item* item;
    UI_Rect rect;
    vec2 pos, vel;
    float32 hover_t;
}

struct UI_Slots {
    Inventory* inv;
    UI_Slot* elements;
    uint32 elements_count;
}

struct UI_Crafting {
    UI_Rect rect;
    UI_Slot[..] slots;
}

struct UI_Inventory_State {
    UI_Slots slots_hotbar;
    UI_Slots slots_backpack;
    UI_Slots slots_chest;

    UI_Slots* slots_to_swap_to;
    UI_Slot* hover_slot;
    UI_Slot select_slot;
    Item select_item;

    UI_Crafting crafting;
}

UI_Inventory_State ui_inventory_state;
void open_inventory(Inventory* hotbar, backpack, chest) {
    player_backpack_open = true;

    let state = *ui_inventory_state;

    state.select_slot.item = *state.select_item;

    float32 slot_size = 1.2 / 9;

    float32 px = 2.0 / app.window_height;
    float32 bottom_padding = slot_size*4; // slot_size/6.0;

    float32 padding = slot_size/4.0;

    UI_Rect hotbar_rect = {};
    hotbar_rect.size = { hotbar.cols, hotbar.rows } * slot_size;
    hotbar_rect.center = {0, -1 + slot_size/2.0 + bottom_padding};

    UI_Rect backpack_rect = {};
    backpack_rect.size = { backpack.cols, backpack.rows } * slot_size;
    backpack_rect.center = hotbar_rect.center + {0, (backpack_rect.size.y + hotbar_rect.size.y)/2.0 + padding};

    UI_Rect crafting_rect = {};
    crafting_rect.size = { backpack.cols, 4 } * slot_size;
    crafting_rect.center = {0, backpack_rect.center.y + (backpack_rect.size.y + crafting_rect.size.y)/2.0 + padding};
    state.crafting.rect = crafting_rect;

    if state.crafting.slots == null  state.crafting.slots = list_create(sizeof UI_Slot);
    list_clear(state.crafting.slots);

    prepare_elements(hotbar_rect, *state.slots_hotbar, hotbar);
    prepare_elements(backpack_rect, *state.slots_backpack, backpack);
    // prepare_elements(*slots_chest, chest);
}

void prepare_elements(UI_Rect rect, UI_Slots* slots, Inventory* inv) {
    slots.inv = inv;

    uint32 rows = slots.inv.rows;
    uint32 cols = slots.inv.cols;

    slots.elements_count = rows*cols;
    slots.elements = realloc(slots.elements, slots.elements_count * sizeof UI_Slot);

    uint32 index = 0;
    for y: 0 .. rows  for x: 0 .. cols {
        UI_Rect slot_rect = grid(rect, rows, cols, x, y);

        UI_Slot slot = {};
        slot.rect = slot_rect;
        slot.item = *inv.items[index];

        slots.elements[index] = slot;
        index++;
    }
}

void stack_item(UI_Slot* dst, src) {
    if dst.item.id == src.item.id {
        dst.item.count += src.item.count;
        src.item.count = 0;
        src.item.id = 0;
    } else {
        Item temp = @dst.item;
        @dst.item = @src.item;
        @src.item = temp;
    }

    swap(*dst.pos, *src.pos);
}

void swap(vec2* a, b) {
    vec2 t = @a;
    @a = @b;
    @b = t;
}

void draw_slots(UI_Inventory_State* state, UI_Slots* slots, next) {
    float32 dt = deltatime();
    float32 px = 2.0 / app.window_height;

    for 0 .. slots.elements_count {
        UI_Slot* slot = *slots.elements[it];
        draw_slot(state, slot, true, next, dt);
    }
}

void draw_slot(UI_Inventory_State* state, UI_Slot* slot, bool draw_bkg, UI_Slots* next, float32 dt) {
    if hover(slot.rect, Input.mouse_pos) {
        state.hover_slot = slot;
        state.slots_to_swap_to = next;
    }

    if draw_bkg {
        float32 px = 2.0 / app.window_height;
        float32 padding = 4*px;
        Color color = lerp(slot.hover_t, opacity(Black, 0.6), opacity(Gray, 0.8));
        draw_rect(pad(slot.rect, padding), color);
    }

    float32 item_scale = lerp(slot.hover_t, 1, 1.2);
    UI_Rect item_rect = {slot.pos, slot.rect.size * item_scale};
    draw_item(item_rect, @slot.item);

    update_slot(slot, slot.rect.center, dt);

    slot.hover_t = clamp01(exp_decay(slot.hover_t, 0, 5, dt));
}

void draw_inventory() {
    float32 dt = deltatime();
    let state = *ui_inventory_state;
    float32 slot_size = 1.2 / 9;

    state.hover_slot = null;
    draw_slots(state, *state.slots_hotbar, *state.slots_backpack);
    draw_slots(state, *state.slots_backpack, *state.slots_hotbar);

    { // crafting
        UI_Rect craft_rect = state.crafting.rect;
        draw_rect(craft_rect, opacity(Black, 0.6));
        for 0 .. list_length(state.crafting.slots) {
            UI_Slot* slot = *state.crafting.slots[it];
            draw_slot(state, slot, true, *state.slots_backpack, dt);
        }

        for 0 .. recipes.length {
            Recipe rec = recipes[it];
            UI_Rect rec_rect = craft_rect;
            rec_rect.size.y = slot_size;
            rec_rect.center.y -= it * slot_size;

            draw_rect(rec_rect, opacity(Black, 0.9));

            // draw_item()
        }
    }


    if state.hover_slot {
        UI_Slot* hover = state.hover_slot;
        UI_Slot* select = *state.select_slot;
        UI_Slot* dest = null;
        int32 dest_index = get_slot_index_for(state.slots_to_swap_to.inv, hover.item.id);
        if dest_index != -1   dest = *state.slots_to_swap_to.elements[dest_index];

        hover.hover_t = 1.0;

        if key_down(Key.left_shift) {
            if dest {
                draw_rect(dest.rect, opacity(White, 0.2));
                if mouse_down(MouseButton.Left) {
                    if hover.item.id != 0  stack_item(dest, hover);
                }
            }
        } else {
            if mouse_pressed(MouseButton.Left) {
                // pickup  placedown  swap
                stack_item(hover, select);
            } else if mouse_pressed(MouseButton.Right) {

                // 
            }
        }
    } else if hover(state.crafting.rect, Input.mouse_pos) {
        if mouse_pressed(MouseButton.Left) and state.select_item.id {
            UI_Slot* slot = list_append(*state.crafting.slots);
            
        }
    }

    if state.select_item.id {
        UI_Slot* slot = *state.select_slot;

        float32 item_scale = 1.5;
        UI_Rect item_rect = {slot.pos, make_vec2(0.133) * item_scale};
        draw_item(item_rect, state.select_item);

        // slot.pos = exp_decay(slot.pos, Input.mouse_pos, 10, dt);

        update_slot(slot, Input.mouse_pos, dt);
    }
}

void update_slot(UI_Slot* slot, vec2 target_pos, float32 dt) {
    slot.pos = slot.pos + slot.vel * dt;

    // These were made static so that I could access them in the debugger
    static float32 P = 450;
    static float32 Td = 0.04;

    vec2 acc = P*(target_pos - slot.pos) - P*Td*slot.vel;
    slot.vel = slot.vel + acc * dt;
}

void draw_item(UI_Rect rect, Item item) {
    if item.id == 0 return;

    ItemInfo info = item_infos[item.id];
    float32 width = rect.size.x;

    float32 sprite_pixel_size = get_sprite_pixel_size(info.sprite).x;
    float32 sprite_scale = width/2.0;
    Transform2D tr = { pos = rect.center, scale = sprite_scale / sprite_pixel_size };
    vec4 color_factor = vec4_one;
    vec4 color_additive = vec4_zero;
    vec4 color_outline = vec4_zero;
    draw_sprite(tr, 0, info.sprite, color_factor, color_additive, color_outline);

    string text = to_string(item.count);

    float32 glyph_height = width/2.0;
    UI_Rect txt_rect = {};
    txt_rect.size = {(glyph_height/2.0) * text.length, glyph_height};
    txt_rect = bottom_right(txt_rect, rect);

    draw_text(center_text(txt_rect, glyph_height, text), glyph_height, text, White);
}

void draw_hotbar(Inventory* hotbar, uint32 index) {
    const hotbar_width = 1.2;
    float32 width = hotbar_width / hotbar.cols;

    float32 px = 2.0 / app.window_height;
    float32 bottom_padding = width/6.0;

    Color color = opacity(Black, 0.7);

    UI_Rect hotbar_rect = {};
    hotbar_rect.size = {hotbar_width, width};
    hotbar_rect.center = {0, -1 + width/2.0 + bottom_padding};

    for 0 .. hotbar.cols {
        UI_Rect rect = div_x(hotbar_rect, hotbar.cols, it);

        draw_rect(pad(rect, 4*px), color);

        Item item = hotbar.items[it];
        draw_item(rect, item);

        if it == index {
            Color selection_highlight_color = opacity(Gray, 0.6);
            draw_rect(pad_top(rect, width*(7/8.0)), selection_highlight_color);
        }
    }
}

