
const player_height = 1.83;
Box box_player = {center={0,-(player_height/2.0 - 0.2),0}, size={0.7, player_height, 0.7}};

Entity player = {
    tr = {scale=vec3_one, rotation=quat_identity},
    aabb = box_player
};

Inventory player_backpack = make_inventory(3, 9);
Inventory player_hotbar = make_inventory(1, 9);
uint32 hotbar_selected_slot = 0;
bool player_backpack_open = false;

float32 player_swing_anim_time = 0;

float32 player_tool_charge = 0;

Item* player_held_item() return *player_hotbar.items[hotbar_selected_slot];

enum Entitykind {
    Player;
    Item;
}

struct Entity {
    Entitykind kind;

    Transform tr;
    Box aabb;

    vec3 vel;

    Item item_stack;

    float32 cooldown;
    uint32 hp;

    bool is_grounded;
}

struct World {
    Entity[..] entity_pool;
}

World world = {
    entity_pool = list_create(sizeof Entity)
};

Entity* spawn_item(vec3 pos, vel, Item item, float32 cooldown) {
    Entity* en = list_append(*world.entity_pool);
    @en = {};
    en.kind = .Item;
    en.aabb = {vec3_zero, vec3_one*0.5};
    en.item_stack = item;
    en.tr = transform_default();
    en.tr.position = pos;
    en.vel = vel;
    en.cooldown = cooldown;
    return en;
}

Entity* spawn_entity(vec3 pos, vel) {
    Entity* en = list_append(*world.entity_pool);
    @en = {};
    en.kind = .Player;
    en.aabb = box_player
    en.tr = transform_default();
    en.tr.position = pos;
    en.vel = vel;
    en.hp = 100;
    return en;
}

struct BlockInter {
    vec3 normal;
    float32 depth;
}

struct Box { vec3 center, size; }

Box box_overlap(vec3 p1, s1, p2, s2) {
    vec3 min1 = p1 - s1*0.5;
    vec3 max1 = p1 + s1*0.5;
    vec3 min2 = p2 - s2*0.5;
    vec3 max2 = p2 + s2*0.5;

    vec3 min3 = max(min1, min2);
    vec3 max3 = min(max1, max2);

    return { (min3 + max3) * 0.5, max3 - min3 };
}

BlockInter box_inter(Box b1, b2) {
    let o = box_overlap(b1.center, b1.size, b2.center, b2.size);
    let s = o.size;
    let r = b1.center - b2.center;
    if s.x < s.y and s.x < s.z {
        return { vec3_unit_x*sign(r.x), s.x };
    } else if s.y < s.z {
        return { vec3_unit_y*sign(r.y), s.y };
    } else {
        return { vec3_unit_z*sign(r.z), s.z };
    }
}

void collide_aabb(Entity* en) {

    let size = en.aabb.size;
    let pos = en.tr.position + en.aabb.center;

    let half_size = size * 0.5;
    let mi = make_ivec(round(pos - half_size));
    let mx = make_ivec(round(pos + half_size));

    vec3 move = {};

    BlockInter deepest_inter = {};

    en.is_grounded = false;
    for z: mi.z .. mx.z+1 {
        for y: mi.y .. mx.y+1 {
            for x: mi.x .. mx.x+1 {
                let id = get_block(make_ivec(x, y, z));
                if id == 0 continue;

                vec3 block_pos = make_vec(x,y,z);

                if false {
                    gizmo_box(block_pos, vec3_one, Green);

                    let box = box_overlap(pos, size, block_pos, vec3_one);
                    gizmo_box(box.center, box.size, Blue);
                }

                let inter = box_inter({pos,size} as Box, {block_pos,vec3_one} as Box);
                let disp = inter.normal*inter.depth;
                if abs(disp.x) > abs(move.x) move.x = disp.x;
                if abs(disp.y) > abs(move.y) move.y = disp.y;
                if abs(disp.z) > abs(move.z) move.z = disp.z;

                if deepest_inter.depth < inter.depth  deepest_inter = inter;

                if inter.normal.y > 0  en.is_grounded = true;
            }
        }
    }

    float32 mass = 1.0;
    float32 e = 0;
    if en.kind == .Item {
        e = 0.8;
    }

    float32 cof_k = 0.5;
    float32 cof_s = 1.2 * cof_k;
    if sqlength(Input.wasd) > 0 {
        cof_k = 0.1;
        cof_s = 0;
    }

    en.vel = calc_new_vel(en.vel, deepest_inter.normal, mass, e, cof_s, cof_k);
    en.tr.position = en.tr.position + move;
}



void entity_update(Entity* en, float32 dt) {
    en.vel.y -= 9.8*dt;
    en.tr.position = en.tr.position + en.vel*dt;

    if en.cooldown > 0.0   en.cooldown -= dt;

    collide_aabb(en);

    if en.item_stack.id != 0 {
        rotate(*en.tr, vec3_unit_y, Pi*dt);

        if sqdist(player.tr.position, en.tr.position) < sq(1.5) and en.cooldown <= 0.0 {
            look_at(*en.tr, player.tr.position);

            if add_item(*player_hotbar, en.item_stack) or add_item(*player_backpack, en.item_stack) {
                list_remove(world.entity_pool, en);
            }
        }
    }


    gizmo_box(en.tr.position + en.aabb.center, en.aabb.size, White);
}

void world_update(World* w, float32 dt) {
    for 0 .. list_length(w.entity_pool) {
        let en = *w.entity_pool[it];
        entity_update(en, dt);
    }
}

vec2 ray_aabb_intersects(vec3 o,d,  l,h) {
    vec3 t_low  = (l - o) / d;
    vec3 t_high = (h - o) / d;
    vec3 t_close = min(t_low, t_high);
    vec3 t_far   = max(t_low, t_high);

    return make_vec(max_axis(t_close), min_axis(t_far));
}

struct Entity_Raycast_Result {
    Entity* en;
    vec3 hit_point;
    float32 min_dist, max_dist;
}

Entity_Raycast_Result entity_raycast(World* w, vec3 o,d, float32 max_dist) {
    Entity_Raycast_Result result = {};
    float32 dist = max_dist;

    for 0 .. list_length(w.entity_pool) {
        let en = *w.entity_pool[it];

        vec3 pos = en.tr.position + en.aabb.center;
        vec3 hsize = en.aabb.size*0.5;

        vec3 p1 = pos - hsize;
        vec3 p2 = pos + hsize;
        vec2 ts = ray_aabb_intersects(o,d, p1, p2);
        float32 min_d = ts.x;
        float32 max_d = ts.y;

        if min_d > 0.0
        if min_d <= max_d
        if min_d <= dist {
            result.en = en;
            result.min_dist = min_d;
            result.max_dist = max_d;
            result.hit_point = o + d * result.min_dist;
            dist = min_d;
        }
    }

    return result;
}

void draw_quad(DeferredRenderer* R, Sprite sprite, Material_PBR material, mat4 model) {
    update_buffer(R.ubo_model.buffer_id, sizeof mat4, *model);

    bind_texture2D(sprite.tex.gl_handle, 0);
    set_uniform("u_uv_offset", sprite.uv_offset);
    set_uniform("u_uv_scale", sprite.uv_scale);
    set_uniform("albedo_color", material.albedo);
    set_uniform("metallic",     material.metallic);
    set_uniform("roughness",    material.roughness);

    glDisable(GL_CULL_FACE);
    draw_elements(db_quad3D);
    glEnable(GL_CULL_FACE);
}


