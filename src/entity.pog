struct Stats {
    float32 max_speed;
    float32 acc_time;
    float32 jump_height;
    float32 jump_time;
}

// https://www.desmos.com/calculator/kfakkr7c2j
float32 player_gravity() return -8.0 * player.stats.jump_height / sq(player.stats.jump_time);
float32 player_jump_vel() return 4.0 * player.stats.jump_height / player.stats.jump_time;


Inventory player_backpack = make_inventory(3, 9);
Inventory player_hotbar = make_inventory(1, 9);
uint32 hotbar_selected_slot = 0;
bool player_backpack_open = false;

// bool player_holding_entity = false;
// vec3 player_held_entity_offset;
// float32 player_held_entity_distance;

Item* player_held_item() return *player_hotbar.items[hotbar_selected_slot];

bool player_recive_item(Item item) {
    return add_item(*player_hotbar, item) or add_item(*player_backpack, item);
}

bool player_can_recieve_item(Item item) {
    return can_add_item(*player_hotbar, item) or can_add_item(*player_backpack, item);
}

struct BlockDamage {
    ivec3 coord;
    uint32 hp;
    uint16 block_id;
}

BlockDamage[..] block_damage_data = list_create(sizeof BlockDamage);

BlockDamage* get_block_damage(ivec3 coord) {
    for 0 .. list_length(block_damage_data) {
        if equals(block_damage_data[it].coord, coord) {
            return *block_damage_data[it];
        }
    }

    return null;
}

void set_block_hp(ivec3 coord, uint32 hp) {
    uint16 block_id = get_block(coord);
    let info = block_infos[block_id];

    BlockDamage* block_hp = get_block_damage(coord);
    uint32 actual_hp = block_hp ? block_hp.hp : info.max_hp;

    if hp != actual_hp {
        if block_hp == null {
            block_hp = list_append(*block_damage_data);
            block_hp.coord = coord;
            block_hp.block_id = block_id;
        }

        block_hp.hp = hp;
    }
}

bool damage_block(ivec3 coord, uint32 dmg) {
    BlockDamage* block_dmg = get_block_damage(coord);

    if block_dmg == null {
        block_dmg = list_append(*block_damage_data);
        block_dmg.coord = coord;
        block_dmg.block_id = get_block(coord);

        let info = block_infos[block_dmg.block_id];
        block_dmg.hp = info.max_hp;
    }

    block_dmg.hp -= min(block_dmg.hp, dmg);

    return block_dmg.hp == 0;
}

enum Entitykind {
    Other;

    Freed;
    Despawn;

    Player;
    Item;
    Block;
    Bush;
    Torch;
}

struct Entity {
    Entitykind kind;

    Transform tr;
    Box aabb;

    vec3 vel;

    Item item_stack;
    uint16 block_id;

    float cooldown;
    uint32 hp;

    float mass;
    float bounciness;
    float cof_k, cof_s;

    bool is_grounded;
    bool grid_aligned;
}

struct Particle_Cube {
    Box aabb;
    vec3 vel;
}

struct World {
    Entity[..] entity_pool;
    // Entity* entity_pool;
    // Entity*[..] free_list;
    // uint32 entity_count;
}

World world = {
    entity_pool = list_create(sizeof Entity)
};

