void world_draw(DeferredRenderer* R, World* w) {

    list_clear(draw_command_quads.instance_data);
    list_clear(draw_command_cubes.instance_data);


    Item* item_hand = player_held_item();
    if item_hand.id != 0 {
        ItemInfo info = item_infos[item_hand.id];

        vec3 offset = make_vec(-(player_en.aabb.size.x * 1.3 / 2.0), -0.3, 0.5);

        float32 d90 = Pi/4.0;
        float32 d45 = d90/2.0;
        quat rotation = axis_angle(vec3_unit_y, -d90*2) * axis_angle(vec3_unit_x, -(d90+d45));

        vec3 bottom_left = {-0.5, 0.5, 0};
        quat tool_charge_rot = axis_angle(vec3_unit_z, d90 * player.tool_charge);
        let model = rotate(mat4_id, tool_charge_rot, bottom_left) * make_mat4(offset, vec3_one, rotation) * to_matrix(player_en.tr);
        Material_PBR mat = {{1,1,1}, 0.1, 0.1};
        draw_quad(info.sprite, mat, model);
    }

    for 0 .. list_length(block_damage_data) {
        BlockDamage* bd = *block_damage_data[it];

        uint16 block_id = get_block(bd.coord);
        BlockInfo info = block_infos[block_id];

        if bd.hp == 0
        or block_id != bd.block_id
        {
            list_unordered_remove(block_damage_data, it);
            it--;
            continue;
        }

        draw_block_cracks(make_vec(bd.coord), bd.hp, info);
    }


    for 0 .. list_length(w.entity_pool) {
        let en = *w.entity_pool[it];

        // Transform tr = en.tr;
        // tr.scale = tr.scale * en.aabb.size;
        // tr.position = tr.position + en.aabb.center;
        mat4 model = to_matrix(en.tr);

        Material_PBR mat      = {{1,1,1}, 0.1, 0.1};
        Material_PBR mat_bush = {{1,1,1}, 0.0, 0.5};

        ItemInfo info = item_infos[en.item_stack.id];

        switch (en.kind) {
        case .Item: {
            draw_shadow(en.tr.position, en.aabb, (en.tr.scale * en.aabb.size).x);

            if info.block_id   draw_cube(info.sprite, mat, model);
            else               draw_quad(info.sprite, mat, model);
        } break;

        case .Player: {
            draw_cube(make_sprite(*white_texture), mat, model);
        } break;

        case .Block: {
            BlockInfo info = block_infos[en.block_id];
            draw_cube(info.sprite, mat, model);
            draw_block_cracks(en.tr.position, en.hp, info);
        } break;

        case .Bush: {
            draw_x_planes(sprite_bush, mat_bush, mat4_scale(1, 1, 1) * model);
        } break;

        case .Torch: {
            // draw_cube(info.sprite, mat, model);
            draw_x_planes(info.sprite, mat, mat4_scale(1, 1, 1) * model);
        } break;
        }
    }

    issue_draw_command(*draw_command_quads);
    issue_draw_command(*draw_command_cubes);
}

